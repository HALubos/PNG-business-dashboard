# Zkopíruj na .env.local a uprav dle potřeby
# (heslo odpovídá docker-compose.yml)

# --- Databáze (lokální PostgreSQL z docker-compose) ---
DATABASE_URL="postgresql://dashboard:dashboard@localhost:5432/dashboard?schema=public"

# --- Auth.js / NextAuth ---
# Vygeneruj: openssl rand -base64 32
AUTH_SECRET="zmen-me-na-nahodny-retezec"
NEXTAUTH_URL="http://localhost:3000"

# --- Aplikace ---
NODE_ENV="development"

# --- Seed (volitelné; default heslo123) ---
SEED_ADMIN_PASSWORD="heslo123"
SEED_REP_PASSWORD="heslo123"

# --- Modul skladovosti: XML feed s naší aktuální skladovostí ---
# Tajný hash — vyžádej si vlastní URL exportu.
STOCK_FEED_URL="https://pinguin.24gate.com/exporter/?hash=ZMEN-ME"

# --- Marketingová větev: konektory + scheduler ---
# Klíč pro šifrování tokenů konektorů at-rest (openssl rand -base64 32).
CONNECTOR_ENC_KEY="zmen-me-na-nahodny-retezec"
# Interval in-process scheduleru synchronizace konektorů (minuty; default 60).
MARKETING_SYNC_INTERVAL_MIN="60"
# Od kdy stahovat historii při prvním připojení konektoru (default 2025-01-01).
MARKETING_BACKFILL_FROM="2025-01-01"

# --- GA4 (OAuth konektor pro Google Analytics 4) ---
# Client ID/secret z Google Cloud konzole (OAuth 2.0 Client, typ „Web application").
# Do „Authorized redirect URIs" přidej: <NEXTAUTH_URL>/api/connectors/ga4/callback
# a <NEXTAUTH_URL>/api/connectors/google-ads/callback (Google Ads sdílí tento client).
# (lokálně http://localhost:3000/api/connectors/ga4/callback). Zapni Analytics Data API.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# --- Google Ads (OAuth konektor – náklady/imprese/prokliky/konverze) ---
# Sdílí GOOGLE_OAUTH_CLIENT_ID/SECRET výše + developer token z Google Ads API Center
# (API Center → API access). Zapni Google Ads API v Google Cloud projektu.
GOOGLE_ADS_DEVELOPER_TOKEN=""

# --- Meta Ads (OAuth konektor – náklady/imprese/prokliky/konverze) ---
# App ID/secret z Meta for Developers (App → Settings → Basic). Do „Valid OAuth
# Redirect URIs" přidej: <NEXTAUTH_URL>/api/connectors/meta-ads/callback.
# App potřebuje povolení Marketing API (scope ads_read).
META_APP_ID=""
META_APP_SECRET=""
