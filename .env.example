# Zkopíruj na .env.local a uprav dle potřeby
# (heslo odpovídá docker-compose.yml)

# --- Databáze (lokální PostgreSQL z docker-compose) ---
DATABASE_URL="postgresql://dashboard:dashboard@localhost:5432/dashboard?schema=public"

# --- Auth.js / NextAuth ---
# Vygeneruj: openssl rand -base64 32
AUTH_SECRET="zmen-me-na-nahodny-retezec"
NEXTAUTH_URL="http://localhost:3000"

# --- Aplikace ---
NODE_ENV="development"

# --- Seed (volitelné; default heslo123) ---
SEED_ADMIN_PASSWORD="heslo123"
SEED_REP_PASSWORD="heslo123"

# --- Modul skladovosti: XML feed s naší aktuální skladovostí ---
# Tajný hash — vyžádej si vlastní URL exportu.
STOCK_FEED_URL="https://pinguin.24gate.com/exporter/?hash=ZMEN-ME"

# --- Marketingová větev: konektory + scheduler ---
# Klíč pro šifrování tokenů konektorů at-rest (openssl rand -base64 32).
CONNECTOR_ENC_KEY="zmen-me-na-nahodny-retezec"
# Interval in-process scheduleru synchronizace konektorů (minuty; default 60).
MARKETING_SYNC_INTERVAL_MIN="60"
# Od kdy stahovat historii při prvním připojení konektoru (default 2025-01-01).
MARKETING_BACKFILL_FROM="2025-01-01"
